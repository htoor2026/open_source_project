{
  "compilerOptions": {
    "rootDir": "src",
    "moduleResolution": "Node",
    "module": "commonjs",
    "noImplicitAny": true,
    "target": "es2016",
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strictNullChecks": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
